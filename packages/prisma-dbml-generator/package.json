{
  "name": "@__APP_NAME__/prisma-dbml-generator",
  "version": "1.0.0",
  "description": "Prisma DBML Generator (forked from prisma-dbml-generator)",
  "private": true,
  "bin": "./dist/generator.cjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/generator.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --ext .ts --fix",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@prisma/generator-helper": "^7.0.1",
    "@prisma/internals": "^7.0.1"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/notiz-dev/prisma-dbml-generator.git"
  },
  "keywords": [
    "prisma",
    "dbml",
    "generator"
  ],
  "contributors": [
    {
      "name": "Marc Stammerjohann"
    },
    {
      "name": "Gary Großgarten"
    }
  ]
}
