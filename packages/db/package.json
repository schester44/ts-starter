{
  "name": "@__APP_NAME__/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/generated/prisma/client.ts",
      "default": "./src/generated/prisma/client.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate",
    "reset": "prisma migrate reset --force",
    "seed": "prisma db seed",
    "data-migrate": "tsx ./src/data-migrations/runner.ts"
  },
  "dependencies": {
    "@prisma/client": "^6"
  },
  "devDependencies": {
    "dotenv": "^16",
    "prisma": "^6",
    "tsx": "^4",
    "typescript": "^5"
  }
}
