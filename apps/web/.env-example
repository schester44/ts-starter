DATABASE_URL=postgresql://localhost:5432/__APP_NAME__

# Supabase: uncomment and configure these if using Supabase
# DATABASE_URL uses the Supavisor pooler (port 5432 for session mode, 6543 for transaction/serverless)
# DATABASE_URL="postgres://prisma.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"
# DIRECT_DATABASE_URL is used for migrations (bypasses the pooler)
# DIRECT_DATABASE_URL="postgres://prisma.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
BETTER_AUTH_SECRET=dev-secret-do-not-use-in-production
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
